# GitHub personal access token — needs repo scope (issue comments + PR creation)
GITHUB_TOKEN=

# Optional: override which env var name the app reads (default: GITHUB_TOKEN)
# github_auth.token_env in config/agent.yaml

# Webhook HMAC secret — set in GitHub repo settings → Webhooks (optional, skipped if empty)
GITHUB_WEBHOOK_SECRET=

# CLI authentication is handled per-tool, not via env vars:
#   claude   → claude auth login
#   codex    → codex login --device-auth  (or codex login --with-api-key)
#   kiro-cli → kiro-cli auth login
#   gemini   → gemini auth login
# Check auth status: GET /health/readiness

# Optional: use API key instead of device auth for codex
OPENAI_API_KEY=
